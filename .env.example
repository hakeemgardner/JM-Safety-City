# Get a free token at https://account.mapbox.com
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token_here

# Supabase: Project URL and anon key from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Vision API – for "What we see" on the receipt (client-side). Same key as Maps works; enable "Cloud Vision API" in Cloud Console.
VITE_GOOGLE_VISION_API_KEY=AIzaSyCnHGs_ORJLhlIg8ZNI4pEMrXhw4vOyeBU

# Optional: Edge Function also uses Vision (for evaluator). Set GOOGLE_VISION_API_KEY in Supabase Edge Function secrets.
# GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
